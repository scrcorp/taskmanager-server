# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://root:root@localhost:40100/taskmanager

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated in env, or JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://console.hermesops.site","https://app.hermesops.site"]

# App
APP_NAME=TaskManager API
DEBUG=true

# Axiom (API Logging)
AXIOM_API_TOKEN=xaat-your-axiom-api-token
AXIOM_DATASET=your-dataset-name

# SMTP (Brevo)
# 1. Brevo 대시보드 → SMTP & API → SMTP 탭에서 키 발급
# 2. SMTP_USER: Brevo 계정 이메일
# 3. SMTP_PASSWORD: Brevo SMTP 키 (API 키와 다름)
# 4. SMTP_FROM_EMAIL: Brevo에서 인증된 발신 도메인/이메일
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-account@example.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=TaskManager

# 보고서 제출 알림 수신 이메일 (비어있으면 알림 미발송)
REPORT_NOTIFICATION_EMAIL=

# Storage mode ("local" or "s3")
# s3 모드에서 access key 없으면 IAM role 사용 (EC2 배포 시)
STORAGE_MODE=local

# AWS S3 (File upload — presigned URL)
# access key 비어있으면 IAM role 사용 (EC2/ECS 배포 시 권장)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=us-west-2
# S3 fallback 버킷 — staging에서 파일이 없으면 여기서 복사 (prod 버킷)
# STORAGE_FALLBACK_BUCKET=

# 로컬 버킷 디렉토리 (local 모드에서 필수)
LOCAL_BUCKET_DIR=/path/to/project/bucket/dev
# 로컬 fallback 버킷 — worktree에서 파일이 없으면 여기서 복사 (dev 버킷)
# LOCAL_FALLBACK_BUCKET_DIR=

# Storage folder names (S3 key prefix / local subfolder)
# STORAGE_FOLDER_REVIEWS=reviews
# STORAGE_FOLDER_COMPLETIONS=completions
# STORAGE_FOLDER_PROFILES=profiles
# STORAGE_FOLDER_ANNOUNCEMENTS=announcements
# STORAGE_FOLDER_ISSUES=issues

# Server base URL (로컬 이미지 URL, presigned URL 등에서 사용, 비어있으면 http://localhost:8000)
# SERVER_BASE_URL=http://localhost:8000

# Admin console base URL (이메일 링크 등에서 사용)
ADMIN_BASE_URL=https://console.hermesops.site

# Excel templates (static/ 폴더 내 파일명, 비어있으면 기본값 사용)
# CHECKLIST_SAMPLE_EXCEL_PATH=checklist_template_sample.xlsx
# INVENTORY_TEMPLATE_EXCEL=inventory_import_template.xlsx
